{
  "manifest_version": 3,
  "name": "ReHash",
  "version": "1.0.0",
  "description": "Spaced repetition system for LeetCode and Codeforces problems",
  "icons": {
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://codeforces.com/*",
    "https://api.github.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ReHash",
    "default_icon": {
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["striver-sheet.js", "content-leetcode.js", "review-panel.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://codeforces.com/problemset/problem/*/*", "https://codeforces.com/contest/*/problem/*"],
      "js": ["striver-sheet.js", "content-codeforces.js", "review-panel.js"],
      "run_at": "document_idle"
    }
  ]
}
